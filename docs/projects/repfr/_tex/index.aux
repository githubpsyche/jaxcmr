\@writefile{lof}{\contentsline {figure}{\numberline {16}{\ignorespaces \textbf  {Instance-CMR spacing function.} Simulated spacing curves for mixed vs matched-control lists from Lohnas and Kahana (\citeproc {ref-lohnas2014retrieved}{2014}). The spacing advantage is preserved without blending at test; the model does not reproduce the apparent steeper slope for mixed lists in the data (cf. Figure~\ref {fig-spacing}).}}{42}{figure.caption.61}\protected@file@percent }
\newlabel{fig-icmr_os_spacing}{{16}{42}{\textbf {Instance-CMR spacing function.} Simulated spacing curves for mixed vs matched-control lists from Lohnas and Kahana (\citeproc {ref-lohnas2014retrieved}{2014}). The spacing advantage is preserved without blending at test; the model does not reproduce the apparent steeper slope for mixed lists in the data (cf. Figure~\ref {fig-spacing})}{figure.caption.61}{}}
